{
  "files.exclude": {},

  "search.exclude": {
    "bin": true,
    "local_release": true,
    "node_modules": true,
    ".build": true,
    ".vscode": true,
    "browser": true,
    "dist": true,
    "package-lock.json": true,
    "tmp-*": true,
    "src/lib/env/**/*.*": true,
    ".firedev": true,
    ".taon": true,
    ".tnp": true,
    "**/bin": true,
    "**/local_release": true,
    "**/node_modules": true,
    "**/.build": true,
    "**/.vscode": true,
    "**/browser": true,
    "**/dist": true,
    "**/package-lock.json": true,
    "**/tmp-*": true,
    "**/src/lib/env/**/*.*": true,
    "**/.firedev": true,
    "**/.taon": true,
    "**/.tnp": true,
    "projects": true,
    "dist-*": true,
    "**/dist-*": true,
    "*.rest": true,
    "**/*.rest": true
  },

  "workbench.colorCustomizations": {
    "activityBar.background": "#5c3735",
    "statusBar.background": "#5c3735",
    "statusBar.debuggingBackground": "#15d8ff"
  },

  "editor.rulers": [
    80,
    120
  ],

  "html.format.wrapAttributes": "force-aligned",
  "workbench.colorTheme": "Default Light+",
  "typescript.tsdk": "node_modules/typescript/lib",

  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "[json5]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "eslint.enable": true,
  "prettier.enable": true,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.inlineSuggest.enabled": true,

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "prettier.endOfLine": "auto",
  "prettier.prettierPath": "./node_modules/prettier",
  "search.useIgnoreFiles": false,

  "search.include": [
    "**/src/**"
  ],

  "window.title": "npm/taon-dev/tnp  [ ${activeEditorShort} ]",

  "json.schemas": [
    {
      "fileMatch": [
        "/docs-config.jsonc"
      ],
      "url": "./docs-config.schema.json"
    },
    {
      "fileMatch": [
        "/taon.jsonc"
      ],
      "url": "./taon-config-standalone.schema.json"
    }
  ],

  "eslint.migration.2_x": "off",

  "cSpell.words": [
    "Initing"
  ],

  "files.watcherExclude": {
    "local_release/**": true,
    "tmp-*/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/dist-nocutsrc/**": true
  },

  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "[dockercompose]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "github.copilot.nextEditSuggestions.enabled": false,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "typescript.suggest.autoImports": false,
  "javascript.suggest.autoImports": false,

  "files.associations": {
    "tsconfig.json": "json"
  },

  "search.followSymlinks": false
}